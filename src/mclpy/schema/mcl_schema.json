{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Microservice Composition Language (MCL) v1.0 reference schema",
  "type": "object",
  "required": ["mcl_version", "title", "services", "components", "dataflows"],
  "additionalProperties": false,
  "properties": {
    "mcl_version": { "type": "string", "enum": ["1.0"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "base_url"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "base_url": { "type": "string", "format": "uri" },
          "description": { "type": "string" }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "binding"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "kind": { "type": "string", "enum": ["map", "timeseries", "kpi", "table"] },
          "title": { "type": "string" },
          "binding": {
            "type": "object",
            "required": ["concept"],
            "additionalProperties": false,
            "properties": {
              "concept": { "type": "string", "format": "uri" },
              "parameter": { "type": "string" },
              "unit": { "type": "string" }
            }
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string", "enum": ["unit", "range", "completeness"] },
                "expected": { "type": "string" },
                "min": { "type": "number" },
                "max": { "type": "number" },
                "min_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
                "expected_points": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "dataflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target", "service", "endpoint"],
        "additionalProperties": false,
        "properties": {
          "target": { "type": "string" },
          "service": { "type": "string" },
          "endpoint": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "event", "target", "effect"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "event": { "type": "string", "enum": ["select", "hover"] },
          "target": { "type": "string" },
          "effect": { "type": "string", "enum": ["filter", "highlight"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
