{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Microservice Composition Language (MCL) v2.0 schema (draft; supersets v1.0)",
  "type": "object",
  "required": ["mcl_version", "title", "services", "components", "dataflows"],
  "additionalProperties": false,
  "properties": {
    "mcl_version": { "type": "string", "enum": ["1.0", "2.0"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "perspective": {
      "type": "string",
      "pattern": "^@[A-Za-z][A-Za-z0-9_-]*$",
      "description": "OOON @perspective: whose representation this composition is. Required when mcl_version is 2.0."
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "base_url"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "base_url": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "binding"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "kind": { "type": "string", "enum": ["map", "timeseries", "kpi", "table"] },
          "title": { "type": "string" },
          "binding": {
            "type": "object",
            "required": ["concept"],
            "additionalProperties": false,
            "properties": {
              "concept": { "type": "string", "format": "uri" },
              "parameter": { "type": "string" },
              "unit": { "type": "string" },
              "marks": { "$ref": "#/definitions/marks" },
              "property_marks": {
                "type": "object",
                "additionalProperties": { "$ref": "#/definitions/marks" },
                "description": "OOON marks per payload property, for components rendering several properties."
              }
            }
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string", "enum": ["unit", "range", "completeness"] },
                "expected": { "type": "string" },
                "min": { "type": "number" },
                "max": { "type": "number" },
                "min_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
                "expected_points": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "dataflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target", "service", "endpoint"],
        "additionalProperties": false,
        "properties": {
          "target": { "type": "string" },
          "service": { "type": "string" },
          "endpoint": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "event", "target", "effect"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "event": { "type": "string", "enum": ["select", "hover"] },
          "target": { "type": "string" },
          "effect": { "type": "string", "enum": ["filter", "highlight", "join"] },
          "trigger": {
            "type": "object",
            "required": ["key"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" }
            },
            "description": "OOON join trigger: the shared key contact rules evaluate on. Grounds v1 filter semantics."
          },
          "description": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "marks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expose": { "type": "boolean" },
        "bound": {
          "type": "string",
          "pattern": "^#[A-Za-z][A-Za-z0-9_-]*$",
          "description": "OOON bound (~): value is withheld; the string is the mandatory #reason."
        },
        "firewall": { "type": "boolean" },
        "drifting": { "type": "boolean" },
        "join_key": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "firewall": { "const": true } }, "required": ["firewall"] },
          "then": {
            "properties": {
              "expose": { "const": false },
              "bound": false,
              "drifting": false,
              "join_key": false
            }
          }
        }
      ],
      "description": "OOON policy marks. Symbols map to terms: ^ expose, ~ bound (+#reason), x firewall, 8/infinity drifting, +(key) join_key. Firewall composes with nothing (spec 1.1)."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "mcl_version": { "const": "2.0" } } },
      "then": { "required": ["mcl_version", "title", "services", "components", "dataflows", "perspective"] }
    },
    {
      "if": { "properties": { "mcl_version": { "const": "1.0" } } },
      "then": {
        "properties": {
          "perspective": false,
          "components": {
            "items": {
              "properties": {
                "binding": {
                  "properties": {
                    "marks": false,
                    "property_marks": false
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
